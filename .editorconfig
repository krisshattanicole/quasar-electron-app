# EditorConfig - Maintain consistent coding styles
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 2
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.yml]
indent_size = 2

[*.json]
indent_size = 2

[*.js]
indent_size = 2

[*.vue]
indent_size = 2

[*.html]
indent_size = 2

[*.css]
indent_size = 2

[*.sass]
indent_size = 2

[*.scss]
indent_size = 2
