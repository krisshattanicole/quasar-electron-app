# Environment Configuration Template
# Copy this file to .env and fill in your values

# GitHub Integration
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_OWNER=krisshattanicole
GITHUB_REPO=quasar-electron-app

# Replit Integration
REPLIT_TOKEN=your_replit_api_token
REPLIT_TEAM=your_team_name

# App Configuration
APP_NAME=QuasarElectronApp
APP_VERSION=1.0.0
APP_DESCRIPTION=Quasar Electron Desktop App with Replit & GitHub Integration

# Build Configuration
BUILD_TARGET=windows
BUILD_ARCH=x64
BUILD_OUTPUT=dist/electron

# Electron Configuration
ELECTRON_VERSION=28.0.0
ELECTRON_BUILDER_VERSION=24.9.1

# Quasar Configuration
QUASAR_MODE=electron
QUASAR_THEME=material

# Development
NODE_ENV=development
DEBUG=false
LOG_LEVEL=info

# API Keys (add your own)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
