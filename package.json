{
  "name": "quasar-electron-app",
  "version": "1.0.0",
  "description": "Quasar Electron Desktop App with Replit & GitHub Integration",
  "productName": "QuasarElectronApp",
  "author": "krisshattanicole",
  "repository": {
    "type": "git",
    "url": "https://github.com/krisshattanicole/quasar-electron-app.git"
  },
  "keywords": [
    "quasar",
    "electron",
    "desktop",
    "replit",
    "vue"
  ],
  "private": true,
  "scripts": {
    "dev": "quasar dev -m electron",
    "build": "quasar build -m electron",
    "build:win": "quasar build -m electron -T windows",
    "replit:dev": "quasar dev -m electron",
    "replit:build": "quasar build -m electron",
    "github:release": "node scripts/github-release.js",
    "setup": "node scripts/setup.js",
    "start": "quasar dev -m electron",
    "clean": "rimraf dist .quasar www node_modules",
    "postinstall": "echo \"✅ Installation complete! Run 'npm run setup' for guided setup.\""
  },
  "dependencies": {
    "@quasar/extras": "^1.16.9",
    "pinia": "^2.1.7",
    "quasar": "^2.14.0",
    "vue": "^3.4.0",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@quasar/app-vite": "^1.7.3",
    "@replit/ai": "^0.0.6",
    "@types/node": "^20.10.0",
    "autoprefixer": "^10.4.16",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "rimraf": "^6.1.3"
  },
  "engines": {
    "node": "^22 || ^20 || ^18",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1"
  }
}
